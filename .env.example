# Withings OAuth2 credentials
# Create app at: https://developer.withings.com/dashboard/
WITHINGS_CLIENT_ID=your_client_id
WITHINGS_CLIENT_SECRET=your_client_secret

# Name of the primary/default user (used when no user param is passed to MCP tools)
WITHINGS_DEFAULT_USER=charles

# LAN IP or hostname of this machine (used for OAuth redirect URL in browser auth UI)
# Must match the redirect URI registered in your Withings developer app
SERVER_HOST=192.168.x.x

# Port for the MCP server (default: 8769)
PORT=8769

# Webhook security
# Random secret embedded in the Withings callback URL — generate with: openssl rand -hex 32
WEBHOOK_SECRET=your_random_secret
# Comma-separated source IPs from Withings (obtain from Withings developer support)
# Leave blank to skip IP allowlisting during initial setup
WITHINGS_WEBHOOK_IPS=

# Optional: brian-mem integration
BRIAN_MEM_URL=
BRIAN_MCP_CLIENT_ID=
BRIAN_MCP_CLIENT_SECRET=

# Per-user tokens are stored in tokens.json (gitignored), not here.
# Authorize family members at: http://<SERVER_HOST>:<PORT>/
