# Withings OAuth2 credentials
# Create app at: https://developer.withings.com/dashboard/
WITHINGS_CLIENT_ID=your_client_id
WITHINGS_CLIENT_SECRET=your_client_secret

# OAuth2 tokens — obtained via initial authorization flow
# Run: node src/authorize.js  to get these
WITHINGS_ACCESS_TOKEN=your_access_token
WITHINGS_REFRESH_TOKEN=your_refresh_token
WITHINGS_TOKEN_EXPIRES_AT=0
